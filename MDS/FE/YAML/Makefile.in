include ../../Makerules
include ../Makerules

PERLBIN:= $(MDSDIR)/$(FEDIR)/BIN
YAMLDIR:= $(ARCHDIR)/$(FEDIR)/$(FAMILY)

ymlnames:= Format.yml Encoding.yml Instruction.yml Synthetic.yml

# Every per-element .yml that Description2MDS.pl emits -- one file per MDD table.
MDD_yaml:= $(MDD_names:%.table=%.yml)

define generate
# Description2MDS.pl emits every per-element .yml ($(MDD_yaml)) from ONE invocation, and
# MDS.yml is then concatenated from the $(ymlnames) subset. Declaring all of them as a
# single grouped target (&:, GNU Make 4.3+) makes this correct under parallel make: the
# recipe runs exactly once, every listed .yml is marked up-to-date together, and no
# consumer (%.pl: %.yml here, or another backend reading e.g. RegClass.yml) can start
# before the whole set has been (re)generated. The previous scheme -- a lone MDS.yml
# target whose recipe `find -delete`d then rewrote the .yml as untracked side effects,
# reached through a `%.yml: MDS.yml` funnel -- raced under -j (a consumer could open a
# .yml mid-delete) and left a removed .yml stale whenever MDS.yml still looked up-to-date.
$(FAMILY)/$(1)/MDS.yml $(addprefix $(FAMILY)/$(1)/, $(MDD_yaml)) &: \
		$(FAMILY)/$(1)/Description.yml $(FAMILY)/$(1)/Bundle.yml $(PERLBIN)/Description2MDS.pl | $(FAMILY)/$(1)
	cat $(FAMILY)/$(1)/Description.yml $(FAMILY)/$(1)/Bundle.yml | \
	    (cd $(FAMILY)/$(1)/ ; CORE=$(1) $(PERL) $(PERLBIN)/Description2MDS.pl )
	@echo "#" > $(FAMILY)/$(1)/MDS.yml
	@echo "# MDS.yml" >> $(FAMILY)/$(1)/MDS.yml
	@echo "# Generated by concatenation of the Yaml files: $(ymlnames)" >> $(FAMILY)/$(1)/MDS.yml
	@echo "#" >> $(FAMILY)/$(1)/MDS.yml
	cat $(addprefix $(FAMILY)/$(1)/, $(ymlnames)) | sed -e 's/^---[^a-zA-Z_0-9]*$$$$//' >> $(FAMILY)/$(1)/MDS.yml

$(FAMILY)/$(1)/Opcode.txt: $(PERLBIN)/Opcode2txt.pl $(FAMILY)/$(1)/MDS.yml
	$(PERL) $$^ > $$@

all: $(FAMILY)/$(1)/Opcode.txt

# Depend on the family source YAML so that editing any of them re-triggers the
# recursion below (which regenerates Description.yml via cpp). Without these
# prerequisites make treats an existing Description.yml as up-to-date and never
# recurses, so downstream tables silently keep stale FE output after a source edit.
$(FAMILY)/$(1)/Description.yml: $(wildcard $(ARCHDIR)/$(FEDIR)/$(FAMILY)/*.yml)
	$(MAKE) -C $(FAMILY) $(1)

$(FAMILY)/$(1)/Bundle.yml: $(ARCHDIR)/$(FEDIR)/$(FAMILY)/makeBundle.pl | $(FAMILY)/$(1)
	CORE=$(1) $(PERL) $$^ > $$@

# Order-only: the per-core output dir must exist before any .yml is written into it.
# (Description.yml's recursion also creates it, but under -j Bundle.yml/the grouped
# rule can run first, so make the dependency explicit rather than order-of-luck.)
$(FAMILY)/$(1):
	mkdir -p $$@

$(FAMILY)/$(1)/%.pl: $(FAMILY)/$(1)/%.yml
	$(PERL) $(PERLINC) $(PERLBIN)/yml2pl.pl $$^ > $$@	|| $(ABORT2)

$(FAMILY)/$(1)/%.table: $(FAMILY)/$(1)/%.pl
	CORE=$(1) $(PERL) $(PERLINC) $$^ > $$@	|| $(ABORT2)
endef

$(foreach CORE,$(CORES),$(eval $(call generate,$(CORE))))

opcode_refs = $(foreach CORE,$(CORES),$(addprefix $(FAMILY)/$(CORE)/, Opcode.txt.ref))
description_refs = $(foreach CORE,$(CORES),$(addprefix $(FAMILY)/$(CORE)/, Description.yml.ref))

diff:

%.diff:
	$(DIFF) $* $(REFDIR)/$(FEDIR)/$*

refs: $(opcode_refs) $(description_refs)

%.ref:
	mkdir -p $(dir $(REFDIR)/$(FEDIR)/$*)
	cp -p $* $(REFDIR)/$(FEDIR)/$*

