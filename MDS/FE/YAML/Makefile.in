include ../../Makerules
include ../Makerules

PERLBIN:= $(MDSDIR)/$(FEDIR)/BIN
YAMLDIR:= $(ARCHDIR)/$(FEDIR)/$(FAMILY)

ymlnames:= Format.yml Encoding.yml Instruction.yml Synthetic.yml

define generate
# MDS.yml generates all .yml in the process (not only the one in ymlnames)
$(FAMILY)/$(1)/MDS.yml: $(PERLBIN)/Description2MDS.pl
$(FAMILY)/$(1)/MDS.yml: $(FAMILY)/$(1)/Description.yml $(FAMILY)/$(1)/Bundle.yml
	find $(FAMILY)/$(1) -maxdepth 1 -name '*.yml' ! -name Description.yml ! -name Bundle.yml -delete
	cat $(FAMILY)/$(1)/Description.yml $(FAMILY)/$(1)/Bundle.yml | \
	    (cd $(FAMILY)/$(1)/ ; CORE=$(1) $(PERL) $(PERLBIN)/Description2MDS.pl )
	@echo "#" > $$@
	@echo "# MDS.yml" >> $$@
	@echo "# Generated by contatenation of the Yaml files: $(ymlnames)" >> $$@
	@echo "#" >> $$@
	cat $(addprefix $(FAMILY)/$(1)/, $(ymlnames)) | sed -e 's/^---[^a-zA-Z_0-9]*$$$$//' >> $$@

$(FAMILY)/$(1)/Opcode.txt: $(PERLBIN)/Opcode2txt.pl $(FAMILY)/$(1)/MDS.yml
	$(PERL) $$^ > $$@

all: $(FAMILY)/$(1)/Opcode.txt

# This rules is needed so that the implicit rules below find their .yml inputs
$(FAMILY)/$(1)/%.yml: $(FAMILY)/$(1)/MDS.yml
	-

$(FAMILY)/$(1)/Description.yml:
	$(MAKE) -C $(FAMILY) $(1)

$(FAMILY)/$(1)/Bundle.yml: $(ARCHDIR)/$(FEDIR)/$(FAMILY)/makeBundle.pl
	CORE=$(1) $(PERL) $$^ > $$@

$(FAMILY)/$(1)/%.pl: $(FAMILY)/$(1)/%.yml
	$(PERL) $(PERLINC) $(PERLBIN)/yml2pl.pl $$^ > $$@	|| $(ABORT2)

$(FAMILY)/$(1)/%.table: $(FAMILY)/$(1)/%.pl
	CORE=$(1) $(PERL) $(PERLINC) $$^ > $$@	|| $(ABORT2)
endef

$(foreach CORE,$(CORES),$(eval $(call generate,$(CORE))))

MDD_yaml  = $(MDD_names:%.table=%.yml)
opcode_refs = $(foreach CORE,$(CORES),$(addprefix $(FAMILY)/$(CORE)/, Opcode.txt.ref))
description_refs = $(foreach CORE,$(CORES),$(addprefix $(FAMILY)/$(CORE)/, Description.yml.ref))

diff:

%.diff:
	$(DIFF) $* $(FAMDIR)/$(FEDIR)/$*

refs: $(opcode_refs) $(description_refs)

%.ref:
	mkdir -p $(dir $(FAMDIR)/$(FEDIR)/$*)
	cp -p $* $(FAMDIR)/$(FEDIR)/$*

