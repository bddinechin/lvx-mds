FAMDIR:= @FAMDIR@
TOPDIR:= @TOPDIR@

INPUTDIR:= $(FAMDIR)/FE/YAML/lvx
OUTPUTDIR:= $(TOPDIR)/FE/YAML/lvx

CORES:= lvx_v1

DIRS:=$(addprefix $(OUTPUTDIR)/,$(CORES))
DESCS:=$(addsuffix /Description.yml,$(DIRS))

core_gen_uc=$(shell echo '$1' | tr 'a-z' 'A-Z' | sed -e 's/_V[0-9].*//')

YMLNAMES:= Builtin.yml Convention.yml Format.yml Generic.yml Immediate.yml Instruction.yml \
	Modifier.yml NativeType.yml Platform.yml Processor.yml RegClass.yml RegField.yml \
	RegFile.yml Relocation.yml Reservation.yml Resource.yml Scheduling.yml Simulated.yml \
	Storage.yml Synthetic.yml
YMLFILES:= $(addprefix $(INPUTDIR)/,$(YMLNAMES))

all: ${CORES}

${CORES}: %: $(OUTPUTDIR)/%/Description.yml

${DESCS}: $(OUTPUTDIR)/%/Description.yml: $(YMLFILES) | $(OUTPUTDIR)/%
	@echo "Generate description for $*"
	( echo '## Description.yml' ; echo ; \
	  echo '#define _KV4_' ; echo '#define _$(shell echo $* | tr a-z A-Z)_' ; echo ; \
	  cat $(YMLFILES) ) | cpp -E -P -undef -nostdinc -D_$(call core_gen_uc,$*)_RV_ - -o $@

.PHONY: install all clean ${CORES}

$(OUTPUT_DIR) $(DIRS):
	mkdir -p $@

install: | ${OUTPUTDIR}
	cp makeBundle.pl ${OUTPUTDIR}/

clean:
	rm ${DESCS}

