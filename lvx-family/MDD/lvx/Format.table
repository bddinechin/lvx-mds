<Format
  ID=	"Format-lvx-LSU_LSBI"
  encoding=	"Encoding-lvx-simple"
  operands=	"Operand-lvx-registerW Operand-lvx-registerY Operand-lvx-registerZ Operand-lvx-variant"
  patterns=	"Pattern-lvx-LSU_LSBI.lsucode5 Pattern-lvx-LSU_LSBI.lsucode4 Pattern-lvx-LSU_LSBI.steering"
  properties=	"%0: MemoryRead %1: Loaded %2: Offset %3: Base"
  syntax=	"%0%4 %1 = %2[%3]"
  what=	"LSU Load Scalar Base + Index"
><Execution>
stage ID:
new variant = %4;
new doscale = 0;
stage RR:
new base = %3;
new index = %2;
new scaling = doscale ? %0.MemorySize : 1;
new address = base + (index * scaling);
@Instruction
stage CR:
%1 = result1;
</Execution><Behavior>
(SEQ
  (WRITE.variant (ACCESS.ID.%4))
  (WRITE.doscale (CONST.0))
  (WRITE.base (ACCESS.RR.%3))
  (WRITE.index (ACCESS.RR.%2))
  (WRITE.scaling
    (SELECT
      (I2B (READ.doscale))
      (PROPERTY.MemorySize.%0)
      (CONST.1)))
  (WRITE.address
    (ADD
      (READ.base)
      (MUL
        (READ.index)
        (READ.scaling))))
  (MACRO.Instruction)
  (COMMIT.CR.%1 (READ.result1)))
</Behavior></Format>
