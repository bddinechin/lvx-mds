        (READ.stopbit))))
  (WRITE.mask
    (ZX.64
      (ADD
        (SUB
          (SHL
            (CONST.2)
            (READ.stopbit))
          (SHL
            (SUB
              (CONST.2)
              (READ.bias))
            (READ.startbit)))
        (SUB
          (READ.bias)
          (CONST.1)))))
