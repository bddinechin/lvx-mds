idle(1);
</Execution><Behavior>
(EFFECT.RR.idle (CONST.1))
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx-BCU:STOP"
  formats=	"Format-lvx-BCU_IPC"
  mnemonic=	"stop"
  patterns=	"Pattern-lvx-BCU_IPC:BCU:STOP.bcucode3"
  processors=	"Processor-lvx_v1-cpu"
  schedulings=	"Scheduling-lvx-ALL"
  what=	"Wait for power controller wake-up."
><Execution>
stage RR:
if (stop_owner()) {
  idle(2);
} else {
  _THROW(PRIVILEGE);
}
</Execution><Behavior>
(SEQ
  (IF
    (TEST.stop_owner)
    (EFFECT.RR.idle (CONST.2))
    (THROW.RR.PRIVILEGE)))
</Behavior></Instruction>
