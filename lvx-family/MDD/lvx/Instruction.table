)
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx-BCU:CALL"
  formats=	"Format-lvx-BCU_UB"
  mnemonic=	"call"
  patterns=	"Pattern-lvx-BCU_UB:BCU:CALL.bcucode1"
  processors=	"Processor-lvx_v1-cpu"
  schedulings=	"Scheduling-lvx-BCU_XFER"
  what=	"Call Subroutine PC-Relative"
><Execution>
stage ID:
new next = NPC;
NPC = PC + argument1;
stage RR:
RA = next;
</Execution><Behavior>
(SEQ
  (WRITE.next
    (F2I.64 (LOAD.ID (AGGL.NPC (CONST.0) (CONST.1)))))
  (WRITE.address
    (ADD
      (F2I.64 (LOAD.ID (AGGL.PC (CONST.0) (CONST.1))))
      (READ.argument1)))
  (STORE.ID (AGGL.NPC (CONST.0) (CONST.1))
    (I2F.64 (READ.address)))
  (STORE.RR (AGGL.SFR (CONST.RA) (CONST.1))
    (I2F.64 (READ.next)))
  (EFFECT.ID.branch_info (CONST.1) (READ.address)))
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx-BCU:CALLX"
  formats=	"Format-lvx-BCU_UB.X"
  mnemonic=	"callx"
  patterns=	"Pattern-lvx-BCU_UB.X:BCU:CALLX.bcucode1"
  processors=	"Processor-lvx_v1-cpu"
  schedulings=	"Scheduling-lvx-BCU2.X"
  what=	"Call Subroutine Extended PC-Relative"
><Execution>
stage ID:
new next = NPC;
NPC = PC + argument1;
stage RR:
RA = next;
</Execution><Behavior>
(SEQ
  (WRITE.next
    (F2I.64 (LOAD.ID (AGGL.NPC (CONST.0) (CONST.1)))))
  (WRITE.address
    (ADD
      (F2I.64 (LOAD.ID (AGGL.PC (CONST.0) (CONST.1))))
      (READ.argument1)))
  (STORE.ID (AGGL.NPC (CONST.0) (CONST.1))
    (I2F.64 (READ.address)))
  (STORE.RR (AGGL.SFR (CONST.RA) (CONST.1))
    (I2F.64 (READ.next)))
  (EFFECT.ID.branch_info (CONST.1) (READ.address)))
</Behavior></Instruction>
