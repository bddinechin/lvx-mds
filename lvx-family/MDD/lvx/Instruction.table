  formats=	"Format-lvx-BCU_IPC"
  mnemonic=	"await"
  patterns=	"Pattern-lvx-BCU_IPC:BCU:AWAIT.bcucode3"
  processors=	"Processor-lvx_v1-cpu"
  schedulings=	"Scheduling-lvx-ALL"
  what=	"Wait for any event or interrupt."
><Execution>
stage RR:
idle(0);
</Execution><Behavior>
(EFFECT.RR.idle (CONST.0))
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx-BCU:SLEEP"
  formats=	"Format-lvx-BCU_IPC"
  mnemonic=	"sleep"
  patterns=	"Pattern-lvx-BCU_IPC:BCU:SLEEP.bcucode3"
  processors=	"Processor-lvx_v1-cpu"
  schedulings=	"Scheduling-lvx-ALL"
  what=	"Wait for an eligible interrupt."
><Execution>
