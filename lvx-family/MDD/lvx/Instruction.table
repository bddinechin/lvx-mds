<Instruction
  ID=	"Instruction-lvx-BCU:RET"
  formats=	"Format-lvx-BCU_RTS"
  mnemonic=	"ret"
  patterns=	"Pattern-lvx-BCU_RTS:BCU:RET.bcucode3"
  processors=	"Processor-lvx_v1-cpu"
  schedulings=	"Scheduling-lvx-BCU_XFER"
  what=	"Return from Call"
><Execution>
stage ID:
NPC = RA;
</Execution><Behavior>
(SEQ
  (STORE.ID (AGGL.NPC (CONST.0) (CONST.1))
    (LOAD.ID (AGGL.SFR (CONST.RA) (CONST.1))))
  (EFFECT.RR.branch_info (CONST.1)
    (F2I.64 (LOAD.ID (AGGL.SFR (CONST.RA) (CONST.1)))))
  (EFFECT.RR.srhpc_update)
)
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx-BCU:RFE"
  formats=	"Format-lvx-BCU_RTS"
  mnemonic=	"rfe"
  patterns=	"Pattern-lvx-BCU_RTS:BCU:RFE.bcucode3"
  processors=	"Processor-lvx_v1-cpu"
  properties=	"%0: Privilege"
  schedulings=	"Scheduling-lvx-ALL"
  what=	"Return from Exception"
><Execution>
stage ID:
if (rfe_owner()) {
  rfe();
}
</Execution><Behavior>
(SEQ
  (IF
    (TEST.rfe_owner)
    (SEQ
      (EFFECT.RR.rfe)
      (EFFECT.RR.branch_info (CONST.1)
        (F2I.64 (LOAD.ID (AGGL.SFR (CONST.SPC) (CONST.1)))))
      (EFFECT.RR.srhpc_update)
    )
    (SKIP)))
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx-BCU:IGOTO"
  formats=	"Format-lvx-BCU_IBC"
  mnemonic=	"igoto"
  patterns=	"Pattern-lvx-BCU_IBC:BCU:IGOTO.bcucode3"
  processors=	"Processor-lvx_v1-cpu"
  schedulings=	"Scheduling-lvx-BCU_XFER_BRRP"
  what=	"Indirect Branch from Register"
><Execution>
stage RR:
NPC = argument1;
</Execution><Behavior>
(SEQ
  (STORE.RR (AGGL.NPC (CONST.0) (CONST.1))
    (I2F.64 (READ.argument1)))
  (EFFECT.RR.branch_info (CONST.1) (READ.argument1))
  (EFFECT.RR.srhpc_update)
  )
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx-BCU:ICALL"
  formats=	"Format-lvx-BCU_IBC"
  mnemonic=	"icall"
  patterns=	"Pattern-lvx-BCU_IBC:BCU:ICALL.bcucode3"
  processors=	"Processor-lvx_v1-cpu"
  schedulings=	"Scheduling-lvx-BCU_XFER_BRRP"
  what=	"Indirect Call from Register"
><Execution>
stage ID:
new next = NPC;
stage RR:
NPC = argument1;
RA = next;
</Execution><Behavior>
(SEQ
  (WRITE.next
    (F2I.64 (LOAD.ID (AGGL.NPC (CONST.0) (CONST.1)))))
  (STORE.RR (AGGL.NPC (CONST.0) (CONST.1))
    (I2F.64 (READ.argument1)))
  (STORE.RR (AGGL.SFR (CONST.RA) (CONST.1))
    (I2F.64 (READ.next)))
  (EFFECT.RR.branch_info (CONST.1) (READ.argument1)))
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx-BCU:SCALL"
  formats=	"Format-lvx-BCU_SCR Format-lvx-BCU_SCI"
  mnemonic=	"scall"
  patterns=	"Pattern-lvx-BCU_SCR:BCU:SCALL.bcucode2 Pattern-lvx-BCU_SCI:BCU:SCALL.bcucode2"
  processors=	"Processor-lvx_v1-cpu"
  schedulings=	"Scheduling-lvx-ALL Scheduling-lvx-ALL"
  what=	"System Call"
><Execution>
stage ID:
syscall(argument1);
</Execution><Behavior>
(SEQ
  (EFFECT.ID.syscall (READ.argument1))
  (EFFECT.ID.branch_info (CONST.1) (READ.argument1)))
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx-BCU:LOOPDO"
  formats=	"Format-lvx-BCU_HLS"
  mnemonic=	"loopdo"
  patterns=	"Pattern-lvx-BCU_HLS:BCU:LOOPDO.bcucode2"
  processors=	"Processor-lvx_v1-cpu"
  schedulings=	"Scheduling-lvx-ALL"
  what=	"Hardware Loop setup and Do execute"
><Execution>
stage ID:
if (!PS.HLE) {
  _THROW(OPCODE);
} else {
  LS = NPC;
  LE = PC + _SX_32(argument2);
  LC = _ZX_64(argument1);
}
</Execution><Behavior>
(SEQ
  (IF (NOTL (I2B (F2I.1 (LOAD.ID (AGGL.PS (CONST.PS_HLE) (CONST.1))))))
    (THROW.ID.OPCODE)
    (SKIP))
  (STORE.E2 (AGGL.SFR (CONST.LS) (CONST.1))
    (LOAD.E2 (AGGL.NPC (CONST.0) (CONST.1))))
  (STORE.E2 (AGGL.SFR (CONST.LE) (CONST.1))
    (I2F.64
      (ADD
        (F2I.64 (LOAD.E2 (AGGL.PC (CONST.0) (CONST.1))))
        (SX.32 (READ.argument2)))))
  (EFFECT.ID.invalpfb)
  (STORE.ID (AGGL.SFR (CONST.LC) (CONST.1))
    (I2F.64 (ZX.64 (READ.argument1))))))
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx-BCU:WFXL"
  formats=	"Format-lvx-BCU_WFX Format-lvx-BCU_WFXA Format-lvx-BCU_WFXHW"
  mnemonic=	"wfxl"
  patterns=	"Pattern-lvx-BCU_WFX:BCU:WFXL.bcucode3 Pattern-lvx-BCU_WFXA:BCU:WFXL.bcucode3 Pattern-lvx-BCU_WFXHW:BCU:WFXL.bcucode3"
  processors=	"Processor-lvx_v1-cpu"
  schedulings=	"Scheduling-lvx-BCU2 Scheduling-lvx-ALL Scheduling-lvx-BCU2"
  what=	"Effects on Least Significant Word System Register"
><Execution>
if (wfxl_check_access(@1, @2)) {
  new setmask = argument2.32[1];
  new clrmask = argument2.32[0];
  result1 = (argument1 &amp; ~clrmask) | setmask;
}
</Execution><Behavior>
(SEQ
  (IF (TEST.wfxl_check_access (METHOD.%1) (METHOD.%2))
    (WRITE.result1
      (APPLY.wfxl (METHOD.%1) (ZX.64 (READ.argument2))))
    (SKIP)))
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx-BCU:WFXM"
  formats=	"Format-lvx-BCU_WFX Format-lvx-BCU_WFXA Format-lvx-BCU_WFXHW"
  mnemonic=	"wfxm"
  patterns=	"Pattern-lvx-BCU_WFX:BCU:WFXM.bcucode3 Pattern-lvx-BCU_WFXA:BCU:WFXM.bcucode3 Pattern-lvx-BCU_WFXHW:BCU:WFXM.bcucode3"
  processors=	"Processor-lvx_v1-cpu"
  schedulings=	"Scheduling-lvx-BCU2 Scheduling-lvx-ALL Scheduling-lvx-BCU2"
  what=	"Word Effects on Most Significant Word System Register"
><Execution>
if (wfxm_check_access(@1, @2)) {
  new setmask = argument2.32[1] &lt;&lt; 32;
  new clrmask = argument2.32[0] &lt;&lt; 32;
  result1 = (argument1 &amp; ~clrmask) | setmask;
}
</Execution><Behavior>
(SEQ
  (IF (TEST.wfxm_check_access (METHOD.%1) (METHOD.%2))
    (WRITE.result1
      (APPLY.wfxm (METHOD.%1) (ZX.64 (READ.argument2))))
    (SKIP)))
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx-BCU:GET"
  formats=	"Format-lvx-BCU_GSR Format-lvx-BCU_GSRHW"
  mnemonic=	"get"
  patterns=	"Pattern-lvx-BCU_GSR:BCU:GET.bcucode3 Pattern-lvx-BCU_GSRHW:BCU:GET.bcucode3"
  processors=	"Processor-lvx_v1-cpu"
  schedulings=	"Scheduling-lvx-BCU2_TINY_LSU Scheduling-lvx-BCU2_TINY_LSU"
  what=	"Get System Register"
><Execution>
stage RR:
if (get_check_access(@2, @1)) {
  new result1 = get(@2, _ZX_64(argument2));
}
</Execution><Behavior>
(IF (TEST.get_check_access (METHOD.%2) (METHOD.%1))
  (WRITE.result1
    (APPLY.get (METHOD.%2) (ZX.64 (READ.argument2))))
  (SKIP))
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx-BCU:IGET"
  formats=	"Format-lvx-BCU_IGSR"
  mnemonic=	"iget"
  patterns=	"Pattern-lvx-BCU_IGSR:BCU:IGET.bcucode3"
  processors=	"Processor-lvx_v1-cpu"
  schedulings=	"Scheduling-lvx-BCU2_TINY_LSU"
  what=	"Indirect Get System Register"
><Execution>
stage RR:
if (get_check_access(index, @1)) {
  new result1 = get(index, SFR[index]);
}
</Execution><Behavior>
(IF (TEST.get_check_access (READ.index) (METHOD.%1))
  (WRITE.result1
    (APPLY.get
      (READ.index) (F2I.64 (LOAD.RR (AGGL.SFR (READ.index) (CONST.1))))))
  (SKIP))
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx-BCU:SET"
  formats=	"Format-lvx-BCU_SET Format-lvx-BCU_SETA Format-lvx-BCU_SETRA Format-lvx-BCU_SETHW"
  mnemonic=	"set"
  patterns=	"Pattern-lvx-BCU_SET:BCU:SET.bcucode3 Pattern-lvx-BCU_SETA:BCU:SET.bcucode3 Pattern-lvx-BCU_SETRA:BCU:SET.bcucode3 Pattern-lvx-BCU_SETHW:BCU:SET.bcucode3"
  processors=	"Processor-lvx_v1-cpu"
  schedulings=	"Scheduling-lvx-BCU2 Scheduling-lvx-ALL Scheduling-lvx-BCU2 Scheduling-lvx-BCU2"
  what=	"Set System Register"
><Execution>
stage RR:
if (set_check_access(@1, argument2, @2)) {
  new result1 = _ZX_64(argument2);
  stage E3:
  %1 = result1;
}
</Execution><Behavior>
(IF (TEST.set_check_access (METHOD.%1) (ZX.64 (READ.argument2)) (METHOD.%2))
  (SEQ
    (WRITE.result1 (ZX.64 (READ.argument2)))
    (COMMIT.E3.%1 (READ.result1)))
  (SKIP))
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx-BCU:RSWAP"
  formats=	"Format-lvx-BCU_RSWAP Format-lvx-BCU_RSWAPA Format-lvx-BCU_RSWAPHW"
  mnemonic=	"rswap"
  patterns=	"Pattern-lvx-BCU_RSWAP:BCU:RSWAP.bcucode3 Pattern-lvx-BCU_RSWAPA:BCU:RSWAP.bcucode3 Pattern-lvx-BCU_RSWAPHW:BCU:RSWAP.bcucode3"
  processors=	"Processor-lvx_v1-cpu"
  schedulings=	"Scheduling-lvx-BCU2_TINY_LSU Scheduling-lvx-ALL Scheduling-lvx-BCU2_TINY_LSU"
  what=	"General and System Register Swap"
><Execution>
stage E1:
new result2 = _ZX_64(argument1);
new result1 = _ZX_64(argument2);
</Execution><Behavior>
(IF (ANDL
      (TEST.get_check_access (METHOD.%2) (METHOD.%1))
      (TEST.set_check_access (METHOD.%2) (ZX.64 (READ.argument1)) (METHOD.%1)))
  (SEQ
    (WRITE.result2 (ZX.64 (READ.argument1)))
    (WRITE.result1 (ZX.64 (READ.argument2)))
    (COMMIT.E1.%1 (READ.result1))
    (COMMIT.E1.%2 (READ.result2)))
  (SKIP))
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx-BCU:WAITIT"
  formats=	"Format-lvx-BCU_PGI"
  mnemonic=	"waitit"
  patterns=	"Pattern-lvx-BCU_PGI:BCU:WAITIT.bcucode3"
  processors=	"Processor-lvx_v1-cpu"
  schedulings=	"Scheduling-lvx-BCU2_TINY_LSU"
  what=	"Wait for Interrupt"
><Execution>
stage RR:
new ormask = argument1 &amp; 0xFFFFFFFF;
new andmask = argument1.32[1];
new result1 = waitit(ormask, andmask);
%1 = result1;
</Execution><Behavior>
(SEQ
  (WRITE.ormask
    (AND (READ.argument1) (CONST.0xFFFFFFFF)))
  (WRITE.andmask
    (READ.32[1].argument1))
  (WRITE.result1
    (APPLY.waitit (READ.ormask) (READ.andmask)))
  (COMMIT.RR.%1 (READ.result1)))
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx-BCU:SYNCGROUP"
  formats=	"Format-lvx-BCU_PGI"
  mnemonic=	"syncgroup"
  patterns=	"Pattern-lvx-BCU_PGI:BCU:SYNCGROUP.bcucode3"
  processors=	"Processor-lvx_v1-cpu"
  schedulings=	"Scheduling-lvx-BCU2"
  what=	"Synchronize Group of Cores"
><Execution>
stage RR:
if (!syncgroup_owner()) {
  _THROW(PRIVILEGE);
} else {
  new waitclrF = argument1 &amp; 0xFFFF;
  new waitclrB = (argument1 &gt;&gt; 16) &amp; 0xFFFF;
  new notifyF = (argument1 &gt;&gt; 32) &amp; 0xFFFF;
  new notifyB = (argument1 &gt;&gt; 48) &amp; 0xFFFF;
  syncgroup(waitclrF, waitclrB, notifyF, notifyB);
}
</Execution><Behavior>
(IF
  (NOTL (TEST.syncgroup_owner))
  (THROW.RR.PRIVILEGE)
  (SEQ
    (WRITE.waitclrF
      (AND (READ.argument1) (CONST.0xFFFF)))
    (WRITE.waitclrB
      (AND (SHR (READ.argument1) (CONST.16)) (CONST.0xFFFF)))
    (WRITE.notifyF
      (AND (SHR (READ.argument1) (CONST.32)) (CONST.0xFFFF)))
    (WRITE.notifyB
      (AND (SHR (READ.argument1) (CONST.48)) (CONST.0xFFFF)))
    (EFFECT.RR.syncgroup
      (READ.waitclrF)
      (READ.waitclrB)
      (READ.notifyF)
      (READ.notifyB))))
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx-BCU:GOTO"
  formats=	"Format-lvx-BCU_UB"
  mnemonic=	"goto"
  patterns=	"Pattern-lvx-BCU_UB:BCU:GOTO.bcucode1"
  processors=	"Processor-lvx_v1-cpu"
  schedulings=	"Scheduling-lvx-BCU_XFER"
  what=	"Branch Unconditional PC-Relative"
><Execution>
stage ID:
NPC = PC + argument1;
</Execution><Behavior>
(SEQ
  (WRITE.address
    (ADD
      (F2I.64 (LOAD.ID (AGGL.PC (CONST.0) (CONST.1))))
      (READ.argument1)))
  (STORE.ID (AGGL.NPC (CONST.0) (CONST.1))
    (I2F.64 (READ.address)))
  (EFFECT.ID.branch_info (CONST.1) (READ.address))
  (EFFECT.RR.srhpc_update)
)
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx-BCU:GOTOX"
  formats=	"Format-lvx-BCU_UB.X"
  mnemonic=	"gotox"
  patterns=	"Pattern-lvx-BCU_UB.X:BCU:GOTOX.bcucode1"
  processors=	"Processor-lvx_v1-cpu"
  schedulings=	"Scheduling-lvx-BCU2.X"
  what=	"Branch Unconditional Extended PC-Relative"
><Execution>
stage ID:
NPC = PC + argument1;
</Execution><Behavior>
(SEQ
  (WRITE.address
    (ADD
      (F2I.64 (LOAD.ID (AGGL.PC (CONST.0) (CONST.1))))
      (READ.argument1)))
  (STORE.ID (AGGL.NPC (CONST.0) (CONST.1))
    (I2F.64 (READ.address)))
  (EFFECT.ID.branch_info (CONST.1) (READ.address))
