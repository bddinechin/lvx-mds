
<Instruction
  ID=	"Instruction-lvx_v2-"
  formats=	"Format-lvx_v2-"
  mnemonic=	"#UNDEF"
  schedulings=	"Scheduling-lvx_v2-"
/>
<Instruction
  ID=	"Instruction-lvx_v2-BCU:AWAIT"
  formats=	"Format-lvx_v2-BCU_IPC"
  mnemonic=	"await"
  patterns=	"Pattern-lvx_v2-BCU_IPC:BCU:AWAIT.bcucode3"
  schedulings=	"Scheduling-lvx_v2-ALL"
  what=	"Wait for any event or interrupt."
><Execution>
stage RR:
idle(0);
</Execution><Behavior>
(EFFECT.RR.idle (CONST.0))
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx_v2-BCU:SLEEP"
  formats=	"Format-lvx_v2-BCU_IPC"
  mnemonic=	"sleep"
  patterns=	"Pattern-lvx_v2-BCU_IPC:BCU:SLEEP.bcucode3"
  schedulings=	"Scheduling-lvx_v2-ALL"
  what=	"Wait for an eligible interrupt."
><Execution>
stage RR:
idle(1);
</Execution><Behavior>
(EFFECT.RR.idle (CONST.1))
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx_v2-BCU:STOP"
  formats=	"Format-lvx_v2-BCU_IPC"
  mnemonic=	"stop"
  patterns=	"Pattern-lvx_v2-BCU_IPC:BCU:STOP.bcucode3"
  schedulings=	"Scheduling-lvx_v2-ALL"
  what=	"Wait for power controller wake-up."
><Execution>
stage RR:
if (stop_owner()) {
  idle(2);
} else {
  _THROW(PRIVILEGE);
}
</Execution><Behavior>
(SEQ
  (IF
    (TEST.stop_owner)
    (EFFECT.RR.idle (CONST.2))
    (THROW.RR.PRIVILEGE)))
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx_v2-BCU:BARRIER"
  formats=	"Format-lvx_v2-BCU_IPC"
  mnemonic=	"barrier"
  patterns=	"Pattern-lvx_v2-BCU_IPC:BCU:BARRIER.bcucode3"
  properties=	"%0: MemoryFence"
  schedulings=	"Scheduling-lvx_v2-ALL"
  what=	"Instruction Pipeline Barrier"
><Execution>
stage RR:
barrier();
</Execution><Behavior>
(EFFECT.RR.barrier)
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx_v2-BCU:TLBREAD"
  formats=	"Format-lvx_v2-BCU_TLB"
  mnemonic=	"tlbread"
  patterns=	"Pattern-lvx_v2-BCU_TLB:BCU:TLBREAD.bcucode3"
  schedulings=	"Scheduling-lvx_v2-ALL"
  what=	"Read TLB Entry"
><Execution>
if (!mmi_owner()) {
  _THROW(PRIVILEGE);
} else {
  readtlb();
}
</Execution><Behavior>
(SEQ
  (IF (NOTL (TEST.mmi_owner))
    (THROW.ID.PRIVILEGE)
    (EFFECT.ID.readtlb)))
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx_v2-BCU:TLBPROBE"
  formats=	"Format-lvx_v2-BCU_TLB"
  mnemonic=	"tlbprobe"
  patterns=	"Pattern-lvx_v2-BCU_TLB:BCU:TLBPROBE.bcucode3"
