<Instruction
  ID=	"Instruction-lvx_v2-BCU:BREAK"
  formats=	"Format-lvx_v2-BCU_BREAK"
  mnemonic=	"break"
  patterns=	"Pattern-lvx_v2-BCU_BREAK:BCU:BREAK.bcucode2"
  schedulings=	"Scheduling-lvx_v2-ALL"
  what=	"Debugger Breakpoint"
><Execution>
stage RR:
break(argument1);
</Execution><Behavior>
(EFFECT.RR.break (READ.argument1))
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx_v2-BCU:RET"
  formats=	"Format-lvx_v2-BCU_RTS"
  mnemonic=	"ret"
  patterns=	"Pattern-lvx_v2-BCU_RTS:BCU:RET.bcucode3"
  schedulings=	"Scheduling-lvx_v2-BCU_XFER"
  what=	"Return from Call"
><Execution>
stage ID:
NPC = RA;
</Execution><Behavior>
(SEQ
  (STORE.ID (AGGL.NPC (CONST.0) (CONST.1))
    (LOAD.ID (AGGL.SFR (CONST.RA) (CONST.1))))
  (EFFECT.RR.branch_info (CONST.1)
    (F2I.64 (LOAD.ID (AGGL.SFR (CONST.RA) (CONST.1)))))
  (EFFECT.RR.srhpc_update)
)
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx_v2-BCU:RFE"
  formats=	"Format-lvx_v2-BCU_RTS"
  mnemonic=	"rfe"
  patterns=	"Pattern-lvx_v2-BCU_RTS:BCU:RFE.bcucode3"
  properties=	"%0: Privilege"
  schedulings=	"Scheduling-lvx_v2-ALL"
  what=	"Return from Exception"
><Execution>
stage ID:
if (rfe_owner()) {
  rfe();
}
</Execution><Behavior>
(SEQ
  (IF
    (TEST.rfe_owner)
    (SEQ
      (EFFECT.RR.rfe)
      (EFFECT.RR.branch_info (CONST.1)
        (F2I.64 (LOAD.ID (AGGL.SFR (CONST.SPC) (CONST.1)))))
      (EFFECT.RR.srhpc_update)
    )
    (SKIP)))
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx_v2-BCU:IGOTO"
  formats=	"Format-lvx_v2-BCU_IBC"
  mnemonic=	"igoto"
  patterns=	"Pattern-lvx_v2-BCU_IBC:BCU:IGOTO.bcucode3"
  schedulings=	"Scheduling-lvx_v2-BCU_XFER_BRRP"
  what=	"Indirect Branch from Register"
><Execution>
stage RR:
NPC = argument1;
</Execution><Behavior>
(SEQ
  (STORE.RR (AGGL.NPC (CONST.0) (CONST.1))
    (I2F.64 (READ.argument1)))
  (EFFECT.RR.branch_info (CONST.1) (READ.argument1))
  (EFFECT.RR.srhpc_update)
  )
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx_v2-BCU:ICALL"
  formats=	"Format-lvx_v2-BCU_IBC"
  mnemonic=	"icall"
  patterns=	"Pattern-lvx_v2-BCU_IBC:BCU:ICALL.bcucode3"
  schedulings=	"Scheduling-lvx_v2-BCU_XFER_BRRP"
  what=	"Indirect Call from Register"
><Execution>
stage ID:
new next = NPC;
stage RR:
NPC = argument1;
RA = next;
</Execution><Behavior>
(SEQ
  (WRITE.next
    (F2I.64 (LOAD.ID (AGGL.NPC (CONST.0) (CONST.1)))))
  (STORE.RR (AGGL.NPC (CONST.0) (CONST.1))
    (I2F.64 (READ.argument1)))
  (STORE.RR (AGGL.SFR (CONST.RA) (CONST.1))
    (I2F.64 (READ.next)))
  (EFFECT.RR.branch_info (CONST.1) (READ.argument1)))
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx_v2-BCU:SCALL"
  formats=	"Format-lvx_v2-BCU_SCR Format-lvx_v2-BCU_SCI"
  mnemonic=	"scall"
  patterns=	"Pattern-lvx_v2-BCU_SCR:BCU:SCALL.bcucode2 Pattern-lvx_v2-BCU_SCI:BCU:SCALL.bcucode2"
  schedulings=	"Scheduling-lvx_v2-ALL Scheduling-lvx_v2-ALL"
  what=	"System Call"
><Execution>
stage ID:
syscall(argument1);
</Execution><Behavior>
(SEQ
  (EFFECT.ID.syscall (READ.argument1))
  (EFFECT.ID.branch_info (CONST.1) (READ.argument1)))
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx_v2-BCU:LOOPDO"
  formats=	"Format-lvx_v2-BCU_HLS"
  mnemonic=	"loopdo"
  patterns=	"Pattern-lvx_v2-BCU_HLS:BCU:LOOPDO.bcucode2"
  schedulings=	"Scheduling-lvx_v2-ALL"
  what=	"Hardware Loop setup and Do execute"
><Execution>
stage ID:
if (!PS.HLE) {
  _THROW(OPCODE);
} else {
  LS = NPC;
  LE = PC + _SX_32(argument2);
  LC = _ZX_64(argument1);
}
</Execution><Behavior>
(SEQ
  (IF (NOTL (I2B (F2I.1 (LOAD.ID (SLICE.1 (AGGL.SRS (CONST.1) (CONST.1)) (CONST.PS_HLE))))))
    (THROW.ID.OPCODE)
    (SKIP))
  (STORE.E2 (AGGL.SFR (CONST.LS) (CONST.1))
    (LOAD.E2 (AGGL.NPC (CONST.0) (CONST.1))))
  (STORE.E2 (AGGL.SFR (CONST.LE) (CONST.1))
    (I2F.64
      (ADD
        (F2I.64 (LOAD.E2 (AGGL.PC (CONST.0) (CONST.1))))
        (SX.32 (READ.argument2)))))
  (EFFECT.ID.invalpfb)
  (STORE.ID (AGGL.SFR (CONST.LC) (CONST.1))
    (I2F.64 (ZX.64 (READ.argument1))))))
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx_v2-BCU:WFXL"
  formats=	"Format-lvx_v2-BCU_WFX Format-lvx_v2-BCU_WFXA Format-lvx_v2-BCU_WFXHW"
  mnemonic=	"wfxl"
  patterns=	"Pattern-lvx_v2-BCU_WFX:BCU:WFXL.bcucode3 Pattern-lvx_v2-BCU_WFXA:BCU:WFXL.bcucode3 Pattern-lvx_v2-BCU_WFXHW:BCU:WFXL.bcucode3"
  schedulings=	"Scheduling-lvx_v2-BCU2 Scheduling-lvx_v2-ALL Scheduling-lvx_v2-BCU2"
  what=	"Effects on Least Significant Word System Register"
><Execution>
if (wfxl_check_access(@1, @2)) {
  new setmask = argument2.32[1];
  new clrmask = argument2.32[0];
  result1 = (argument1 &amp; ~clrmask) | setmask;
}
</Execution><Behavior>
(SEQ
  (IF (TEST.wfxl_check_access (METHOD.%1) (METHOD.%2))
    (WRITE.result1
      (APPLY.64.wfxl (METHOD.%1) (ZX.64 (READ.argument2))))
    (SKIP)))
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx_v2-BCU:WFXM"
  formats=	"Format-lvx_v2-BCU_WFX Format-lvx_v2-BCU_WFXA Format-lvx_v2-BCU_WFXHW"
  mnemonic=	"wfxm"
  patterns=	"Pattern-lvx_v2-BCU_WFX:BCU:WFXM.bcucode3 Pattern-lvx_v2-BCU_WFXA:BCU:WFXM.bcucode3 Pattern-lvx_v2-BCU_WFXHW:BCU:WFXM.bcucode3"
  schedulings=	"Scheduling-lvx_v2-BCU2 Scheduling-lvx_v2-ALL Scheduling-lvx_v2-BCU2"
  what=	"Word Effects on Most Significant Word System Register"
><Execution>
if (wfxm_check_access(@1, @2)) {
  new setmask = argument2.32[1] &lt;&lt; 32;
  new clrmask = argument2.32[0] &lt;&lt; 32;
  result1 = (argument1 &amp; ~clrmask) | setmask;
}
</Execution><Behavior>
(SEQ
  (IF (TEST.wfxm_check_access (METHOD.%1) (METHOD.%2))
    (WRITE.result1
      (APPLY.64.wfxm (METHOD.%1) (ZX.64 (READ.argument2))))
    (SKIP)))
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx_v2-BCU:GET"
  formats=	"Format-lvx_v2-BCU_GSR Format-lvx_v2-BCU_GSRHW"
  mnemonic=	"get"
  patterns=	"Pattern-lvx_v2-BCU_GSR:BCU:GET.bcucode3 Pattern-lvx_v2-BCU_GSRHW:BCU:GET.bcucode3"
  schedulings=	"Scheduling-lvx_v2-BCU2_TINY_LSU Scheduling-lvx_v2-BCU2_TINY_LSU"
  what=	"Get System Register"
><Execution>
stage RR:
if (get_check_access(@2, @1)) {
  new result1 = get(@2, _ZX_64(argument2));
}
</Execution><Behavior>
(IF (TEST.get_check_access (METHOD.%2) (METHOD.%1))
  (WRITE.result1
    (APPLY.64.get (METHOD.%2) (ZX.64 (READ.argument2))))
  (SKIP))
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx_v2-BCU:IGET"
  formats=	"Format-lvx_v2-BCU_IGSR"
  mnemonic=	"iget"
  patterns=	"Pattern-lvx_v2-BCU_IGSR:BCU:IGET.bcucode3"
  schedulings=	"Scheduling-lvx_v2-BCU2_TINY_LSU"
  what=	"Indirect Get System Register"
><Execution>
stage RR:
if (get_check_access(index, @1)) {
  new result1 = get(index, SFR[index]);
}
</Execution><Behavior>
(IF (TEST.get_check_access (READ.index) (METHOD.%1))
  (WRITE.result1
    (APPLY.64.get
      (READ.index) (F2I.64 (LOAD.RR (AGGL.SFR (READ.index) (CONST.1))))))
  (SKIP))
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx_v2-BCU:SET"
  formats=	"Format-lvx_v2-BCU_SET Format-lvx_v2-BCU_SETA Format-lvx_v2-BCU_SETRA Format-lvx_v2-BCU_SETHW"
  mnemonic=	"set"
  patterns=	"Pattern-lvx_v2-BCU_SET:BCU:SET.bcucode3 Pattern-lvx_v2-BCU_SETA:BCU:SET.bcucode3 Pattern-lvx_v2-BCU_SETRA:BCU:SET.bcucode3 Pattern-lvx_v2-BCU_SETHW:BCU:SET.bcucode3"
  schedulings=	"Scheduling-lvx_v2-BCU2 Scheduling-lvx_v2-ALL Scheduling-lvx_v2-BCU2 Scheduling-lvx_v2-BCU2"
  what=	"Set System Register"
><Execution>
stage RR:
if (set_check_access(@1, argument2, @2)) {
  new result1 = _ZX_64(argument2);
  stage E3:
  %1 = result1;
}
</Execution><Behavior>
(IF (TEST.set_check_access (METHOD.%1) (ZX.64 (READ.argument2)) (METHOD.%2))
  (SEQ
    (WRITE.result1 (ZX.64 (READ.argument2)))
    (COMMIT.E3.%1 (READ.result1)))
  (SKIP))
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx_v2-BCU:RSWAP"
  formats=	"Format-lvx_v2-BCU_RSWAP Format-lvx_v2-BCU_RSWAPA Format-lvx_v2-BCU_RSWAPHW"
  mnemonic=	"rswap"
  patterns=	"Pattern-lvx_v2-BCU_RSWAP:BCU:RSWAP.bcucode3 Pattern-lvx_v2-BCU_RSWAPA:BCU:RSWAP.bcucode3 Pattern-lvx_v2-BCU_RSWAPHW:BCU:RSWAP.bcucode3"
  schedulings=	"Scheduling-lvx_v2-BCU2_TINY_LSU Scheduling-lvx_v2-ALL Scheduling-lvx_v2-BCU2_TINY_LSU"
  what=	"General and System Register Swap"
><Execution>
stage E1:
new result2 = _ZX_64(argument1);
new result1 = _ZX_64(argument2);
</Execution><Behavior>
(IF (ANDL
      (TEST.get_check_access (METHOD.%2) (METHOD.%1))
      (TEST.set_check_access (METHOD.%2) (ZX.64 (READ.argument1)) (METHOD.%1)))
  (SEQ
    (WRITE.result2 (ZX.64 (READ.argument1)))
    (WRITE.result1 (ZX.64 (READ.argument2)))
    (COMMIT.E1.%1 (READ.result1))
    (COMMIT.E1.%2 (READ.result2)))
  (SKIP))
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx_v2-BCU:FCSRSW"
  formats=	"Format-lvx_v2-BCU_FCSRSW"
  mnemonic=	"fcsrsw"
  patterns=	"Pattern-lvx_v2-BCU_FCSRSW:BCU:FCSRSW.bcucode3"
  schedulings=	"Scheduling-lvx_v2-BCU2_TINY_LSU"
  what=	"Swap RISC-V FP CSR view of Compute Status with a GPR"
><Execution>
stage E1:
new result1 = (CS.IN &lt;&lt; 0) | (CS.UN &lt;&lt; 1) | (CS.OV &lt;&lt; 2) | (CS.DZ &lt;&lt; 3) | (CS.IO &lt;&lt; 4) | (CS.RM &lt;&lt; 5);
CS.IN = (argument1 &gt;&gt; 0) &amp; 1;
CS.UN = (argument1 &gt;&gt; 1) &amp; 1;
CS.OV = (argument1 &gt;&gt; 2) &amp; 1;
CS.DZ = (argument1 &gt;&gt; 3) &amp; 1;
CS.IO = (argument1 &gt;&gt; 4) &amp; 1;
CS.RM = (argument1 &gt;&gt; 5) &amp; 7;
</Execution><Behavior>
(SEQ
  (WRITE.result1
    (IOR
      (IOR
        (IOR
          (IOR
            (IOR
              (F2I.1 (LOAD.E1 (SLICE.1 (AGGL.SRS (CONST.4) (CONST.1)) (CONST.CS_IN))))
              (SHL (F2I.1 (LOAD.E1 (SLICE.1 (AGGL.SRS (CONST.4) (CONST.1)) (CONST.CS_UN)))) (CONST.1)))
            (SHL (F2I.1 (LOAD.E1 (SLICE.1 (AGGL.SRS (CONST.4) (CONST.1)) (CONST.CS_OV)))) (CONST.2)))
          (SHL (F2I.1 (LOAD.E1 (SLICE.1 (AGGL.SRS (CONST.4) (CONST.1)) (CONST.CS_DZ)))) (CONST.3)))
        (SHL (F2I.1 (LOAD.E1 (SLICE.1 (AGGL.SRS (CONST.4) (CONST.1)) (CONST.CS_IO)))) (CONST.4)))
      (SHL (F2I.3 (LOAD.E1 (SLICE.3 (AGGL.SRS (CONST.4) (CONST.1)) (CONST.CS_RM)))) (CONST.5))))
  (STORE.E1 (SLICE.1 (AGGL.SRS (CONST.4) (CONST.1)) (CONST.CS_IN))
    (I2F.1 (AND (READ.argument1) (CONST.1))))
  (STORE.E1 (SLICE.1 (AGGL.SRS (CONST.4) (CONST.1)) (CONST.CS_UN))
    (I2F.1 (AND (SHR (READ.argument1) (CONST.1)) (CONST.1))))
  (STORE.E1 (SLICE.1 (AGGL.SRS (CONST.4) (CONST.1)) (CONST.CS_OV))
    (I2F.1 (AND (SHR (READ.argument1) (CONST.2)) (CONST.1))))
  (STORE.E1 (SLICE.1 (AGGL.SRS (CONST.4) (CONST.1)) (CONST.CS_DZ))
    (I2F.1 (AND (SHR (READ.argument1) (CONST.3)) (CONST.1))))
  (STORE.E1 (SLICE.1 (AGGL.SRS (CONST.4) (CONST.1)) (CONST.CS_IO))
    (I2F.1 (AND (SHR (READ.argument1) (CONST.4)) (CONST.1))))
  (STORE.E1 (SLICE.3 (AGGL.SRS (CONST.4) (CONST.1)) (CONST.CS_RM))
    (I2F.3 (AND (SHR (READ.argument1) (CONST.5)) (CONST.7))))
  (COMMIT.E1.%1 (READ.result1)))
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx_v2-BCU:WAITIT"
  formats=	"Format-lvx_v2-BCU_PGI"
  mnemonic=	"waitit"
  patterns=	"Pattern-lvx_v2-BCU_PGI:BCU:WAITIT.bcucode3"
  schedulings=	"Scheduling-lvx_v2-BCU2_TINY_LSU"
  what=	"Wait for Interrupt"
><Execution>
stage RR:
new ormask = argument1 &amp; 0xFFFFFFFF;
new andmask = argument1.32[1];
new result1 = waitit(ormask, andmask);
%1 = result1;
</Execution><Behavior>
(SEQ
  (WRITE.ormask
    (AND (READ.argument1) (CONST.0xFFFFFFFF)))
  (WRITE.andmask
    (READ.32[1].argument1))
  (WRITE.result1
    (APPLY.64.waitit (READ.ormask) (READ.andmask)))
  (COMMIT.RR.%1 (READ.result1)))
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx_v2-BCU:SYNCGROUP"
  formats=	"Format-lvx_v2-BCU_PGI"
  mnemonic=	"syncgroup"
  patterns=	"Pattern-lvx_v2-BCU_PGI:BCU:SYNCGROUP.bcucode3"
  schedulings=	"Scheduling-lvx_v2-BCU2"
  what=	"Synchronize Group of Cores"
><Execution>
stage RR:
if (!syncgroup_owner()) {
  _THROW(PRIVILEGE);
} else {
  new waitclrF = argument1 &amp; 0xFFFF;
  new waitclrB = (argument1 &gt;&gt; 16) &amp; 0xFFFF;
  new notifyF = (argument1 &gt;&gt; 32) &amp; 0xFFFF;
  new notifyB = (argument1 &gt;&gt; 48) &amp; 0xFFFF;
  syncgroup(waitclrF, waitclrB, notifyF, notifyB);
}
</Execution><Behavior>
(IF
  (NOTL (TEST.syncgroup_owner))
  (THROW.RR.PRIVILEGE)
  (SEQ
    (WRITE.waitclrF
      (AND (READ.argument1) (CONST.0xFFFF)))
    (WRITE.waitclrB
      (AND (SHR (READ.argument1) (CONST.16)) (CONST.0xFFFF)))
    (WRITE.notifyF
      (AND (SHR (READ.argument1) (CONST.32)) (CONST.0xFFFF)))
    (WRITE.notifyB
      (AND (SHR (READ.argument1) (CONST.48)) (CONST.0xFFFF)))
    (EFFECT.RR.syncgroup
