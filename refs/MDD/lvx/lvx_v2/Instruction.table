    (NOTL (TEST.mmi_owner))
    (THROW.ID.PRIVILEGE)
    (EFFECT.ID.probetlb)))
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx_v2-BCU:TLBWRITE"
  formats=	"Format-lvx_v2-BCU_TLB"
  mnemonic=	"tlbwrite"
  patterns=	"Pattern-lvx_v2-BCU_TLB:BCU:TLBWRITE.bcucode3"
  properties=	"%0: Privilege"
