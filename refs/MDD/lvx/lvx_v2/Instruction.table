<Instruction
  ID=	"Instruction-lvx_v2-ALU:INSF"
  formats=	"Format-lvx_v2-ALU_BFWR"
  mnemonic=	"insf"
  patterns=	"Pattern-lvx_v2-ALU_BFWR:ALU:INSF.wricode1"
  schedulings=	"Scheduling-lvx_v2-ALU_TINY"
  what=	"Insert Bit Field into Word"
><Execution>
stage RR:
new argument1 = %1;
new result1 = ((argument2 &lt;&lt; startbit) &amp; mask) | (argument1 &amp; ~mask);
</Execution><Behavior>
(SEQ
  (WRITE.argument1 (ACCESS.RR.%1))
  (WRITE.result1
    (IOR
      (AND
        (SHL
          (READ.argument2)
          (READ.startbit))
        (READ.mask))
      (AND
        (READ.argument1)
        (NOT (READ.mask))))))
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx_v2-ALU:EXTFZ"
  formats=	"Format-lvx_v2-ALU_BFWR"
  mnemonic=	"extfz"
  patterns=	"Pattern-lvx_v2-ALU_BFWR:ALU:EXTFZ.wricode1"
  schedulings=	"Scheduling-lvx_v2-ALU_TINY"
  what=	"Extract Bit Field and Zero Extend to Double Word"
><Execution>
new masked = argument2 &amp; mask;
new result1 = masked &gt;&gt; startbit;
</Execution><Behavior>
(SEQ
  (WRITE.masked
    (AND
      (READ.argument2)
      (READ.mask)))
  (WRITE.result1
    (SHR
      (READ.masked)
      (READ.startbit))))
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx_v2-ALU:EXTFS"
  formats=	"Format-lvx_v2-ALU_BFWR"
  mnemonic=	"extfs"
  patterns=	"Pattern-lvx_v2-ALU_BFWR:ALU:EXTFS.wricode1"
  schedulings=	"Scheduling-lvx_v2-ALU_TINY"
  what=	"Extract Bit Field and Sign Extend to Double Word"
><Execution>
new masked1 = _ZX_64(argument2 &amp; mask);
new masked2 = _SX_64(argument2 | ~mask);
new negative = argument2 &amp; (mask &amp; ~(mask &gt;&gt; 1));
new masked = negative == 0 ? masked1 : masked2;
new result1 = masked &gt;&gt; startbit;
</Execution><Behavior>
(SEQ
  (WRITE.masked1
    (ZX.64
      (AND
        (READ.argument2)
        (READ.mask))))
  (WRITE.masked2
    (SX.64
      (IOR
        (READ.argument2)
        (NOT (READ.mask)))))
  (WRITE.negative
    (AND
      (READ.argument2)
      (AND
        (READ.mask)
        (NOT
          (SHR
            (READ.mask)
            (CONST.1))))))
  (WRITE.masked
    (SELECT
      (EQ
