</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx_v2-BCU:TLBDINVAL"
  formats=	"Format-lvx_v2-BCU_TLB"
  mnemonic=	"tlbdinval"
  patterns=	"Pattern-lvx_v2-BCU_TLB:BCU:TLBDINVAL.bcucode3"
