<Format
  ID=	"Format-lvx_v1-BCU_CCB"
  encoding=	"Encoding-lvx_v1-simple"
  operands=	"Operand-lvx_v1-ccbcomp Operand-lvx_v1-registerZ Operand-lvx_v1-registerY Operand-lvx_v1-pcrel11s2"
  patterns=	"Pattern-lvx_v1-BCU_CCB.steering"
  properties=	"%0: Control;Conditional %4: Target"
  syntax=	"%0%1 %2, %3 ? %4"
  what=	"BCU Compare Conditional Branches"
><Execution>
stage RR:
new argument1 = %1;
new argument2 = %2;
new argument3 = %3;
new argument4 = %4;
</Execution><Behavior>
(SEQ
  (WRITE.argument1 (ACCESS.RR.%1))
  (WRITE.argument2 (ACCESS.RR.%2))
  (WRITE.argument3 (ACCESS.RR.%3))
  (WRITE.argument4 (ACCESS.RR.%4)))
</Behavior></Format>
