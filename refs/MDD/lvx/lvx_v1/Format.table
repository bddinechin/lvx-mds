<Format
  ID=	"Format-lvx_v1-LSU_LSBO"
  encoding=	"Encoding-lvx_v1-simple"
  operands=	"Operand-lvx_v1-registerW Operand-lvx_v1-signed10 Operand-lvx_v1-registerZ Operand-lvx_v1-variant"
  patterns=	"Pattern-lvx_v1-LSU_LSBO.lsucode4 Pattern-lvx_v1-LSU_LSBO.steering"
  properties=	"%0: MemoryRead %1: Loaded %2: Offset %3: Base"
  syntax=	"%0%4 %1 = %2[%3]"
  what=	"LSU Load Scalar Base Offset"
><Execution>
stage ID:
new variant = %4;
new offset = %2;
stage RR:
new base = %3;
new address = base + offset;
@Instruction
stage CR:
%1 = result1;
</Execution><Behavior>
(SEQ
  (WRITE.variant (ACCESS.ID.%4))
  (WRITE.offset (ACCESS.ID.%2))
  (WRITE.base (ACCESS.RR.%3))
  (WRITE.address
    (ADD
      (READ.base)
      (READ.offset)))
  (MACRO.Instruction)
  (COMMIT.CR.%1 (READ.result1)))
</Behavior></Format>
