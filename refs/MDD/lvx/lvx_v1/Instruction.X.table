  schedulings=	"Scheduling-lvx_v1-ALU_TINY"
  syntax=	"%0 %1 = %2"
  synthetic=	"Synthetic-lvx_v1-ALU:ZXBD"
  what=	"Zero Extend Byte to Double Word"
><Execution>
new masked = argument2 &amp; mask;
new result1 = masked &gt;&gt; startbit;
</Execution><Behavior>
(SEQ
  (WRITE.masked
    (AND
      (READ.argument2)
      (READ.mask)))
  (WRITE.result1
    (SHR
      (READ.masked)
      (READ.startbit))))
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx_v1-ALU:SXBD"
  formats=	"Format-lvx_v1-ALU_BFWR"
  mnemonic=	"sxbd"
  patterns=	"Pattern-lvx_v1-ALU_BFWR:ALU:EXTFS.wricode1 Pattern-lvx_v1-ALU_BFWR:ALU:SXBD.stopbit2_stopbit4 Pattern-lvx_v1-ALU_BFWR:ALU:SXBD.startbit"
  schedulings=	"Scheduling-lvx_v1-ALU_TINY"
  syntax=	"%0 %1 = %2"
  synthetic=	"Synthetic-lvx_v1-ALU:SXBD"
  what=	"Sign Extend Byte to Double Word"
><Execution>
new masked1 = _ZX_64(argument2 &amp; mask);
new masked2 = _SX_64(argument2 | ~mask);
new negative = argument2 &amp; (mask &amp; ~(mask &gt;&gt; 1));
new masked = negative == 0 ? masked1 : masked2;
new result1 = masked &gt;&gt; startbit;
</Execution><Behavior>
(SEQ
  (WRITE.masked1
    (ZX.64
      (AND
        (READ.argument2)
        (READ.mask))))
  (WRITE.masked2
    (SX.64
      (IOR
        (READ.argument2)
        (NOT (READ.mask)))))
  (WRITE.negative
    (AND
      (READ.argument2)
      (AND
        (READ.mask)
        (NOT
          (SHR
            (READ.mask)
            (CONST.1))))))
  (WRITE.masked
    (SELECT
      (EQ
        (READ.negative)
        (CONST.0))
      (READ.masked1)
      (READ.masked2)))
  (WRITE.result1
    (SHR
      (READ.masked)
      (READ.startbit))))
</Behavior></Instruction>
