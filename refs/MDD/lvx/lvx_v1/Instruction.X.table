  product = _SX_64(argument2) * _SX_64(argument3);
}
if (widemult == 1) {
  product = _ZX_64(argument2) * _ZX_64(argument3);
}
if (widemult == 2) {
  product = _SX_64(argument2) * _ZX_64(argument3);
}
result1 = product;
</Execution><Behavior>
