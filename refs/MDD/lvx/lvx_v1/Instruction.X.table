  schedulings=	"Scheduling-lvx_v1-BCU_BRRP2"
  syntax=	"%0"
  synthetic=	"Synthetic-lvx_v1-BCU:ERROP"
  what=	"Error opcode."
><Execution>
stage RR:
if (ccbcomp(argument1, argument2, argument3)) {
  NPC = PC + argument4;
}
</Execution><Behavior>
(IF
  (TEST.ccbcomp (READ.argument1) (READ.argument2) (READ.argument3))
  (SEQ
    (WRITE.address
      (ADD
        (F2I.64 (LOAD.ID (AGGL.PC (CONST.0) (CONST.1))))
        (READ.argument4)))
    (STORE.RR (AGGL.NPC (CONST.0) (CONST.1))
      (I2F.64 (READ.address)))
    (EFFECT.RR.branch_info (CONST.1) (READ.address))
    (EFFECT.RR.srhpc_update))
  (EFFECT.RR.branch_info (CONST.0) (CONST.0)))
</Behavior></Instruction>
