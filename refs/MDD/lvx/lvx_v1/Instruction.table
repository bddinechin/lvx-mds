(EFFECT.RR.barrier)
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx_v1-BCU:TLBREAD"
  formats=	"Format-lvx_v1-BCU_TLB"
  mnemonic=	"tlbread"
  patterns=	"Pattern-lvx_v1-BCU_TLB:BCU:TLBREAD.bcucode3"
  schedulings=	"Scheduling-lvx_v1-ALL"
  what=	"Read TLB Entry"
><Execution>
if (!mmi_owner()) {
  _THROW(PRIVILEGE);
} else {
  readtlb();
}
</Execution><Behavior>
(SEQ
  (IF (NOTL (TEST.mmi_owner))
    (THROW.ID.PRIVILEGE)
    (EFFECT.ID.readtlb)))
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx_v1-BCU:TLBPROBE"
  formats=	"Format-lvx_v1-BCU_TLB"
