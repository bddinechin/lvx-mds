
<Instruction
  ID=	"Instruction-lvx_v1-"
  formats=	"Format-lvx_v1-"
  mnemonic=	"#UNDEF"
  schedulings=	"Scheduling-lvx_v1-"
/>
<Instruction
  ID=	"Instruction-lvx_v1-BCU:AWAIT"
  formats=	"Format-lvx_v1-BCU_IPC"
  mnemonic=	"await"
  patterns=	"Pattern-lvx_v1-BCU_IPC:BCU:AWAIT.bcucode3"
  schedulings=	"Scheduling-lvx_v1-ALL"
  what=	"Wait for any event or interrupt."
><Execution>
stage RR:
idle(0);
</Execution><Behavior>
(EFFECT.RR.idle (CONST.0))
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx_v1-BCU:SLEEP"
  formats=	"Format-lvx_v1-BCU_IPC"
  mnemonic=	"sleep"
  patterns=	"Pattern-lvx_v1-BCU_IPC:BCU:SLEEP.bcucode3"
  schedulings=	"Scheduling-lvx_v1-ALL"
  what=	"Wait for an eligible interrupt."
><Execution>
stage RR:
idle(1);
</Execution><Behavior>
(EFFECT.RR.idle (CONST.1))
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx_v1-BCU:STOP"
  formats=	"Format-lvx_v1-BCU_IPC"
  mnemonic=	"stop"
  patterns=	"Pattern-lvx_v1-BCU_IPC:BCU:STOP.bcucode3"
  schedulings=	"Scheduling-lvx_v1-ALL"
  what=	"Wait for power controller wake-up."
><Execution>
stage RR:
if (stop_owner()) {
  idle(2);
} else {
  _THROW(PRIVILEGE);
}
</Execution><Behavior>
(SEQ
  (IF
    (TEST.stop_owner)
    (EFFECT.RR.idle (CONST.2))
    (THROW.RR.PRIVILEGE)))
</Behavior></Instruction>
<Instruction
  ID=	"Instruction-lvx_v1-BCU:BARRIER"
  formats=	"Format-lvx_v1-BCU_IPC"
